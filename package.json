{
  "name": "tailwind-prod",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./src/css/input.css -o ./dist/css/output.css --watch --source \"./src/**/*.{html,js,ts}\"",
    "dev:html": "cpx \"src/**/*.html\" ./dist --watch --verbose",
    "dev": "npm-run-all --parallel dev:*",
    "build:css": "npx @tailwindcss/cli -i ./src/css/input.css -o ./dist/css/output.css --minify --source \"./src/**/*.{html,js,ts}\"",
    "build:html": "cpx \"src/**/*.html\" dist",
    "build": "npm-run-all build:*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "cpx": "^1.5.0",
    "npm-run-all": "^4.1.5"
  }
}
